# Copie este arquivo para .env e preencha com seus tokens reais
# cp .env.example .env

# Token do bot — obtenha no @BotFather no Telegram
TELEGRAM_TOKEN=seu_token_aqui

# Chave da API do Claude — obtenha em console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# (Opcional) ID do seu usuário no Telegram para restringir acesso
# Descubra enviando /start para @userinfobot no Telegram
ALLOWED_USER_ID=
